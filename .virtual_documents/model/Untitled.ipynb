model.plot(forecast)


import plotly.express as px
import pandas as pd
from country_clustering import cluster_countries

df = pd.read_csv("../data/gdp_data.csv")
df_latest=cluster_countries(df)

fig = px.scatter(
    df_latest,
    x="gdp_growth",
    y="cumulative_growth",
    color="cluster_label",
    hover_name="country",
    title="Country Economic Clusters"
)

fig.show()



